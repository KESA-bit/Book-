:root {
    --bg-dark: #0f1111; 
    --bg-surface: #232f3e;
    --bg-card: #1a1a1a;
    --primary-color: #ff9900; /* Amazon Amber Gold */
    --text-main: #FFFFFF;
    --text-muted: #CCCCCC;
    --accent-red: #cc0c39;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    padding-bottom: 50px;
}

header {
    background-color: #131921;
    padding: 15px 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo {
    font-size: 26px;
    font-weight: 700;
    color: var(--primary-color);
    letter-spacing: 1px;
}

.nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
}

.cart-icon-container {
    position: relative;
    cursor: pointer;
    font-size: 24px;
}

#cart-count {
    position: absolute;
    top: -8px;
    right: -10px;
    background-color: var(--primary-color);
    color: black;
    font-size: 12px;
    font-weight: bold;
    padding: 2px 6px;
    border-radius: 50%;
}

.intro {
    text-align: center;
    padding: 50px 20px 30px 20px;
}

.intro h1 span {
    color: var(--primary-color);
}

.intro p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 10px auto 0 auto;
    font-size: 15px;
}

.products-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 25px;
    padding: 20px;
}

.product-card {
    background-color: var(--bg-card);
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.2s, border-color 0.2s;
}

.product-card:hover {
    transform: translateY(-2px);
    border-color: #444;
}

.product-image {
    width: 100%;
    height: 300px;
    object-fit: contain; /* Perfect for book covers */
    background-color: #111;
    border-radius: 4px;
    cursor: pointer;
}

.product-title {
    font-size: 17px;
    font-weight: 500;
    margin: 12px 0 4px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.product-price {
    color: var(--primary-color);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
}

.btn-primary {
    background-color: var(--primary-color);
    color: black;
    border: none;
    padding: 12px;
    font-weight: 600;
    border-radius: 4px;
    cursor: pointer;
    width: 100%;
    transition: 0.2s;
}

.btn-primary:hover {
    background-color: #e68a00;
}

.btn-secondary {
    background-color: #2a2a2a;
    color: white;
    border: 1px solid #444;
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 5px;
    transition: 0.2s;
}

.btn-secondary:hover {
    background-color: #3a3a3a;
}

.modal {
    display: none;
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background-color: rgba(0,0,0,0.85);
    z-index: 1000;
    justify-content: center; align-items: center;
    overflow-y: auto;
}

.modal-content {
    background-color: #161616;
    padding: 30px;
    border-radius: 8px;
    max-width: 500px;
    width: 90%;
    position: relative;
    margin: 20px auto;
    border: 1px solid #333;
}

.close-btn {
    position: absolute; top: 10px; right: 15px;
    font-size: 28px; cursor: pointer; color: var(--text-muted);
}

/* Image Slider Layout */
.slider-container {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 15px;
    background-color: #000;
}

.slider {
    display: flex;
    transition: transform 0.3s ease-in-out;
    height: 100%;
}

.slider img {
    min-width: 100%;
    height: 100%;
    object-fit: contain;
}

.slider-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(0,0,0,0.6); color: white; border: none;
    padding: 10px 14px; cursor: pointer; font-size: 18px;
    z-index: 10;
    border-radius: 4px;
}

.prev { left: 5px; }
.next { right: 5px; }

form input, form textarea {
    width: 100%; padding: 12px; margin-bottom: 12px;
    background-color: #222; border: 1px solid #3a3a3a;
    color: white; border-radius: 4px;
    font-size: 14px;
}

form input:focus, form textarea:focus {
    border-color: var(--primary-color);
    outline: none;
}

/* Quantity Selection CSS */
.quantity-container {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
    background: #222;
    padding: 10px 12px;
    border-radius: 4px;
    border: 1px solid #3a3a3a;
}

.quantity-container label {
    font-size: 14px;
    color: var(--text-muted);
}

.quantity-container input[type="number"] {
    width: 70px;
    padding: 6px;
    margin-bottom: 0;
    text-align: center;
}

.payment-note { background: #222; padding: 12px; border-left: 3px solid var(--primary-color); margin-bottom: 15px; font-size: 13px; color: var(--text-muted); }
.welcome-back { color: var(--primary-color); font-size: 14px; margin-bottom: 5px; font-weight: 500; }
.cart-total { font-size: 20px; font-weight: bold; color: var(--primary-color); margin: 15px 0; text-align: right; }
.loading { text-align: center; color: var(--text-muted); padding: 20px; width: 100%; grid-column: 1 / -1; }

.order-card {
    background-color: #222;
    padding: 15px;
    border-radius: 6px;
    margin-bottom: 12px;
    border: 1px solid #333;
}
.order-card p {
    font-size: 14px;
    margin-bottom: 4px;
}
